<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_res_config_settings_inherit_walaa_connector" model="ir.ui.view">
        <field name="name">res.config.settings.walaa.connector</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app name="walaa_connector" string="Walaa Connector">
                    <block title="Connection">
                        <setting id="walaa_enabled_setting" string="Enable Walaa Connector" help="Enable per-company sync with Walaa.">
                            <field name="walaa_enabled"/>
                        </setting>
                        <setting id="walaa_brand_token_setting" string="Walaa Brand Token" help="Brand identity sent to Walaa in X-Brand-Token.">
                            <field name="walaa_brand_token" password="True"/>
                        </setting>
                        <setting id="walaa_base_url_setting" string="Walaa Base URL" help="Base URL for Walaa APIs.">
                            <field name="walaa_base_url" placeholder="https://api.walaa.example"/>
                        </setting>
                        <setting id="walaa_order_path_setting" string="Walaa Order Path" help="Relative endpoint path for confirmed order push.">
                            <field name="walaa_order_path"/>
                        </setting>
                    </block>
                    <block title="Tools">
                        <setting id="walaa_test_connection_setting" string="Connection Test" help="Send a test request to the Walaa order endpoint.">
                            <button
                                name="action_test_walaa_connection"
                                type="object"
                                string="Test Walaa Connection"
                                class="btn btn-primary"
                            />
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>
</odoo>
