<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_walaa_integration_job_search" model="ir.ui.view">
        <field name="name">walaa.integration.job.search</field>
        <field name="model">walaa.integration.job</field>
        <field name="arch" type="xml">
            <search string="Walaa Jobs">
                <field name="job_type"/>
                <field name="company_id"/>
                <field name="sale_order_id"/>
                <field name="state"/>

                <filter name="filter_queued" string="Queued" domain="[('state', '=', 'queued')]"/>
                <filter name="filter_processing" string="Processing" domain="[('state', '=', 'processing')]"/>
                <filter name="filter_sent" string="Sent" domain="[('state', '=', 'sent')]"/>
                <filter name="filter_failed" string="Failed" domain="[('state', '=', 'failed')]"/>
                <separator/>
                <filter name="group_job_type" string="Job Type" context="{'group_by': 'job_type'}"/>
                <filter name="group_company" string="Company" context="{'group_by': 'company_id'}"/>
            </search>
        </field>
    </record>

    <record id="view_walaa_integration_job_tree" model="ir.ui.view">
        <field name="name">walaa.integration.job.tree</field>
        <field name="model">walaa.integration.job</field>
        <field name="arch" type="xml">
            <list default_order="create_date desc" create="false">
                <field name="create_date"/>
                <field name="job_type"/>
                <field name="company_id"/>
                <field name="sale_order_id" optional="hide"/>
                <field name="state"/>
                <field name="attempt_count"/>
                <field name="next_retry_at"/>
                <field name="response_status" optional="hide"/>
                <field name="last_error" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="view_walaa_integration_job_form" model="ir.ui.view">
        <field name="name">walaa.integration.job.form</field>
        <field name="model">walaa.integration.job</field>
        <field name="arch" type="xml">
            <form create="false" delete="false">
                <header>
                    <button
                        name="action_resend"
                        type="object"
                        string="Resend"
                        class="btn-primary"
                        invisible="state != 'failed'"
                    />
                    <field name="state" widget="statusbar" statusbar_visible="queued,processing,sent,failed"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="job_type" readonly="1"/>
                            <field name="company_id" readonly="1"/>
                            <field name="sale_order_id" readonly="1"/>
                            <field name="idempotency_key" readonly="1"/>
                        </group>
                        <group>
                            <field name="attempt_count" readonly="1"/>
                            <field name="next_retry_at" readonly="1"/>
                            <field name="response_status" readonly="1"/>
                            <field name="create_date" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Payload">
                            <field name="payload_json" nolabel="1" readonly="1" widget="text"/>
                        </page>
                        <page string="Response">
                            <field name="response_body" nolabel="1" readonly="1" widget="text"/>
                        </page>
                        <page string="Error">
                            <field name="last_error" nolabel="1" readonly="1" widget="text"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_walaa_integration_jobs" model="ir.actions.act_window">
        <field name="name">Walaa Integration Logs</field>
        <field name="res_model">walaa.integration.job</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_walaa_integration_job_search"/>
        <field name="context">{'search_default_filter_failed': 0}</field>
    </record>

    <menuitem id="menu_walaa_connector_root" name="Walaa Connector" parent="sale.sale_menu_config" sequence="96"/>
    <menuitem
        id="menu_walaa_integration_jobs"
        name="Integration Logs"
        parent="menu_walaa_connector_root"
        action="action_walaa_integration_jobs"
        sequence="10"
    />
</odoo>
