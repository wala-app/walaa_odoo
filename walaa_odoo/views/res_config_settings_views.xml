<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_res_config_settings_inherit_walaa" model="ir.ui.view">
        <field name="name">res.config.settings.walaa</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app name="walaa" string="Walaa">
                    <block title="Connection">
                        <setting id="walaa_enabled_setting" string="Enable Walaa" help="Enable per-company sync with Walaa.">
                            <field name="walaa_enabled"/>
                        </setting>
                        <setting id="walaa_brand_token_setting" string="Walaa Brand Token" help="Brand identity sent to Walaa in X-Brand-Token.">
                            <field name="walaa_brand_token" password="True"/>
                        </setting>
                    </block>
                    <block title="Tools">
                        <setting id="walaa_test_connection_setting" string="Connection Test" help="Send a test request to the Walaa order endpoint.">
                            <button
                                name="action_test_walaa_connection"
                                type="object"
                                string="Test Walaa Connection"
                                class="btn btn-primary"
                            />
                        </setting>
                        <setting id="walaa_manual_product_sync_setting" string="Manual Product Sync" help="Send all active saleable products to Walaa.">
                            <button
                                name="action_sync_all_products_now"
                                type="object"
                                string="Sync All Products Now"
                                class="btn btn-secondary"
                            />
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>
</odoo>
